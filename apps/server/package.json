{
  "name": "@bot/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "build": "bun build src/main.ts --outdir dist --target bun",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "latest",
    "@bot/shared": "workspace:*",
    "elysia": "latest",
    "nanoid": "latest"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "latest"
  }
}
